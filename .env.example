# ───────────────────────────────────────────────────────────
# SafeShift API environment (copy to server/.env)
# ───────────────────────────────────────────────────────────

NODE_ENV=development
PORT=4000

# ─── Database ───────────────────────────────────────────────
# OPTION A — Supabase Cloud (no Docker needed). Create a free project at
#   https://supabase.com → Project Settings → Database → Connection string.
#   Use the "Session pooler" or "Direct connection" URI (NOT the transaction
#   pooler on :6543 — Sequelize needs session-level features). SSL auto-enables
#   for remote hosts.
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
#
# OPTION B — Supabase local CLI (still uses Docker under the hood):
#   `supabase start`, then:
# DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres
# DB_SSL=false
#
# OPTION C — Docker Compose Postgres (the default; matches docker-compose.yml).
DB_HOST=localhost
DB_PORT=5544
DB_NAME=safeshift
DB_USER=safeshift
DB_PASSWORD=safeshift
# Force TLS on/off. Unset = auto (on for remote hosts, off for localhost).
# DB_SSL=true

# Auth
JWT_SECRET=dev-only-change-me-in-production
JWT_EXPIRES_IN=7d

# CORS / web origin
WEB_ORIGIN=http://localhost:5173

# Email (Nodemailer). Leave blank to log cert-expiry alerts to console.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM="SafeShift HSE <no-reply@safeshift.app>"

# Cert-expiry scan schedule (cron). Default: every day 07:00.
CERT_SCAN_CRON=0 7 * * *
