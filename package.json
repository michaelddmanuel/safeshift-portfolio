{
  "name": "safeshift",
  "version": "0.1.0",
  "private": true,
  "description": "SafeShift — multi-tenant HSE training & compliance platform (Shell · ExxonMobil · Chevron) on one codebase.",
  "workspaces": [
    "server",
    "client",
    "mobile"
  ],
  "scripts": {
    "dev": "concurrently -n api,web -c blue,magenta \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "npm --workspace server run dev",
    "dev:web": "npm --workspace client run dev",
    "build": "npm --workspace server run build && npm --workspace client run build",
    "db:up": "docker compose up -d db",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f db",
    "seed": "npm --workspace server run seed",
    "mobile:start": "npm --workspace mobile run start",
    "mobile:ios": "npm --workspace mobile run ios",
    "mobile:android": "npm --workspace mobile run android"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "engines": {
    "node": ">=20"
  }
}
